			)
		)
		(uuid "141bc9fb-ddec-415e-930c-1fbf7080bdb0")
	)
	(text "total resistance\n510*5+39=2,589k\ncurrent:\n420/2.589Mohm = 162uA\nmax power\n(162E-6)^2*510E3 =\n0.0134 W\nmuch less than rated 1/8W"
		(exclude_from_sim no)
		(at 474.726 134.62 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "20862f4b-3bc4-4c41-acfc-b4492a49cb2f")
	)
	(text "Inputs"
		(exclude_from_sim no)
		(at 340.614 213.36 0)
		(effects
			(font
				(size 2.54 2.54)
			)
		)
		(uuid "27777916-81d4-46cf-9ade-8b1e62ec87a4")
	)
	(text "1000 A fuse interrupt.\nunder short 420/0.43=976.7A\nAssuming 1A fusing current\n1^2*0.43 = 0.43W <1/2W\nresistors survive operating \nat fuse current"
		(exclude_from_sim no)
		(at 88.138 78.994 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "332f7273-263f-4818-97b2-89b21089f826")
	)
	(text "forward voltage of opto is 1.3v. bias current is \n(12-1.3)/ (2*390) = 0.0137mA, power is\n0.0137^2*390 = 0.0732W\n0805 is rated for 1/8W (0.125W)\n12.5mW>7.32mW, resistor has plenty of margin"
		(exclude_from_sim no)
		(at 395.732 138.938 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "336783bc-aeb4-4603-9b5f-bf415a69792b")
	)
