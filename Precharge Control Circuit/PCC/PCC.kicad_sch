	(text "Resistors are 1W rated. at 100s, 4.2v/cell = 420v\nrule states across TSMP  10 resistors in series\n42v/resistor, 3k ohm\n42^2/3000 = 0.588 W /resistor <<1W"
		(exclude_from_sim no)
		(at 56.896 202.438 0)
